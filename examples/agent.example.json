{
  "brokerUrl": "https://cc-cred.example.com",
  "token": "REPLACE_WITH_THIS_MACHINE_CLIENT_TOKEN",
  "intervalSec": 1800,
  "caCertPath": "",
  "clientCertPath": "~/.config/ccbroker/pki/this-machine.crt",
  "clientKeyPath": "~/.config/ccbroker/pki/this-machine.key",
  "targets": [
    { "cred": "personal", "type": "keychain" },
    { "cred": "work", "type": "file", "path": "~/.claude-work/.credentials.json" }
  ]
}
