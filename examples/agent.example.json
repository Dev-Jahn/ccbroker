{
  "brokerUrl": "https://ccbroker.example.com",
  "token": "REPLACE_WITH_THIS_MACHINE_CLIENT_TOKEN",
  "intervalSec": 1800,
  "caCertPath": "",
  "clientCertPath": "~/.config/ccbroker/pki/this-machine.crt",
  "clientKeyPath": "~/.config/ccbroker/pki/this-machine.key",
  "proxyUrl": "",
  "activeFile": "~/.config/ccbroker/active",
  "autoPolicy": "manual",
  "autoThreshold": 0.95,
  "targets": [
    { "cred": "@active", "type": "file", "path": "~/.claude/.credentials.json" }
  ]
}
